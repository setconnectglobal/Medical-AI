# =============================================================================
# NeuroScan — Environment Variables
# Copy this file to .env and fill in values for local testing:
#   cp .env.example .env
# =============================================================================

# --- Model search (optional override) ---
# MODEL_DIR=.

# --- Server (Railway sets PORT automatically) ---
# PORT=7860
# GRADIO_SERVER_PORT=7860
# GRADIO_ROOT_PATH=

# --- MongoDB Atlas (optional — inference works without it) ---
# Get from Atlas: Connect → Drivers → connection string
# Whitelist your IP (or 0.0.0.0/0 for demos) under Network Access.
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority

# --- Google Gemini (optional — RAG uses rule-engine fallback without it) ---
GEMINI_API_KEY=

# --- AWS S3 (optional — scan upload skipped without these) ---
AWS_S3_BUCKET=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1

# --- RL Q-table override (optional) ---
# Defaults: rl_agent.json or rl_training_metadata (1).json under MODEL_DIR
# RL_QTABLE_PATH=./models/rl_agent.json

# --- Hugging Face cache (optional, useful on Railway volumes) ---
# HF_HOME=/app/.cache/huggingface
